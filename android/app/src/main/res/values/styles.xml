<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base app theme -->
    <style name="Theme.ResoddedFramework" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="colorPrimary">@color/purple_primary</item>
        <item name="colorPrimaryDark">@color/purple_dark</item>
        <item name="colorAccent">@color/purple_accent</item>
        <item name="android:statusBarColor">@color/purple_dark</item>
        <item name="android:navigationBarColor">@color/purple_dark</item>
        <item name="android:windowBackground">@color/purple_gradient_end</item>
    </style>

    <!-- Section title -->
    <style name="SectionTitle" parent="android:Widget.TextView">
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:layout_marginBottom">8dp</item>
        <item name="android:letterSpacing">0.03</item>
    </style>

    <!-- Help/description text -->
    <style name="HelpText" parent="android:Widget.TextView">
        <item name="android:textSize">13sp</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:layout_marginBottom">14dp</item>
        <item name="android:lineSpacingExtra">2dp</item>
    </style>

    <!-- Primary button (purple gradient) -->
    <style name="BtnPrimary" parent="android:Widget.Button">
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:letterSpacing">0.04</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:background">@drawable/btn_primary_gradient</item>
        <item name="android:stateListAnimator">@null</item>
        <item name="android:elevation">4dp</item>
        <item name="android:layout_marginBottom">10dp</item>
    </style>

    <!-- Secondary button (outline) -->
    <style name="BtnSecondary" parent="android:Widget.Button">
        <item name="android:textSize">13sp</item>
        <item name="android:textColor">@color/purple_light</item>
        <item name="android:letterSpacing">0.03</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:background">@drawable/btn_secondary_outline</item>
        <item name="android:stateListAnimator">@null</item>
        <item name="android:layout_marginBottom">10dp</item>
    </style>

    <!-- Launch / Start Game button (green accent) -->
    <style name="BtnLaunch" parent="android:Widget.Button">
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:letterSpacing">0.05</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:background">@drawable/btn_launch_gradient</item>
        <item name="android:stateListAnimator">@null</item>
        <item name="android:elevation">6dp</item>
        <item name="android:layout_marginTop">8dp</item>
    </style>

    <!-- Status badge -->
    <style name="StatusBadge" parent="android:Widget.TextView">
        <item name="android:textSize">15sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:gravity">center</item>
        <item name="android:background">@drawable/bg_status_badge</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
        <item name="android:paddingLeft">16dp</item>
        <item name="android:paddingRight">16dp</item>
        <item name="android:layout_marginBottom">24dp</item>
        <item name="android:lineSpacingExtra">4dp</item>
    </style>
</resources>